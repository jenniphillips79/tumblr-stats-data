eize the means of lamp production.</p><p><a href=\"https://www.reddit.com/user/OnceInOnceSet/\">Reddit </a>- <a href=\"https://www.webtoons.com/en/canvas/of-moths-and-mina/list?title_no=1031366\">Webtoons</a> - <a href=\"https://tapas.io/series/Of-Moths-and-Mina\">Tapas </a>- <a href=\"https://bsky.app/profile/bibleaccuratemoth.bsky.social\">Bluesky</a></p></blockquote>","trail":[{"blog":{"name":"biblicallyaccuratemoth","active":true,"theme":{"header_full_width":686,"header_full_height":386,"avatar_shape":"circle","background_color":"#FFFFFF","body_font":"Helvetica Neue","header_bounds":"","header_image":"https://64.media.tumblr.com/0034ea4b30b8e7d6aba4d36d9c6cd417/780b9739770b7e4c-8f/s2048x901/1b4b241520c49e7aa5509612e2d8ff47dc299cf3.png","header_image_focused":"https://64.media.tumblr.com/0034ea4b30b8e7d6aba4d36d9c6cd417/780b9739770b7e4c-8f/s2048x3072/018b2f8815e933090c5747d84d341662288ac695.png","header_image_poster":"","header_image_scaled":"https://64.media.tumblr.com/0034ea4b30b8e7d6aba4d36d9c6cd417/780b9739770b7e4c-8f/s2048x3072/018b2f8815e933090c5747d84d341662288ac695.png","header_stretch":true,"link_color":"#00B8FF","show_avatar":true,"show_description":true,"show_header_image":true,"show_title":true,"title_color":"#000000","title_font":"Helvetica Neue","title_font_weight":"bold"},"share_likes":true,"share_following":true,"can_be_followed":true},"post":{"id":"811332996793761792"},"content_raw":"<p><div class=\"npf_row\"><figure class=\"tmblr-full\" data-orig-height=\"3900\" data-orig-width=\"2000\"><img src=\"https://64.media.tumblr.com/794649b212f91f9f2df0cb57e722f924/c547874d7678c167-1f/s640x960/81c619903dca38975e4408b6e3251c422996af95.png\" data-orig-height=\"3900\" data-orig-width=\"2000\" srcset=\"https://64.media.tumblr.com/794649b212f91f9f2df0cb57e722f924/c547874d7678c167-1f/s75x75_c1/cb6f84580dc9274fb58de96525e524cba37208de.png 75w, https://64.media.tumblr.com/794649b212f91f9f2df0cb57e722f924/c547874d7678c167-1f/s100x200/8f76d7edfcf421a5a0eec9939e7b